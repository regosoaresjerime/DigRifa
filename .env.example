# APP_URL: URL da aplicação (ex: http://localhost:3000 ou URL de produção)
APP_URL="http://localhost:3000"

# SUPABASE CONFIGURATION
# URL do projeto Supabase (encontrado em Project Settings > API)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Chave anônima pública (encontrada em Project Settings > API)
# Esta chave é segura para usar no cliente (browser)
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# GEMINI API KEY (Opcional, se usar funcionalidades de IA)
GEMINI_API_KEY="your-gemini-api-key"
